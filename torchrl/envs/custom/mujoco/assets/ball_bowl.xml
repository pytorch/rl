<mujoco model="ball_bowl">
  <compiler angle="radian" autolimits="true"/>
  <option timestep="0.002" gravity="0 0 -9.81" integrator="implicitfast" cone="elliptic"/>

  <default>
    <joint damping="1.0" armature="0.01"/>
    <geom contype="1" conaffinity="1" condim="4" friction="1.0 0.02 0.001"/>
    <default class="arm_visual">
      <geom rgba="0.25 0.45 0.75 1"/>
    </default>
    <default class="gripper">
      <geom rgba="0.25 0.25 0.25 1" friction="1.5 0.03 0.003" solimp="0.95 0.99 0.001" solref="0.004 1"/>
    </default>
  </default>

  <asset>
    <texture name="checker" type="2d" builtin="checker" width="256" height="256" rgb1="0.92 0.92 0.88" rgb2="0.72 0.76 0.78"/>
    <material name="floor_mat" texture="checker" texrepeat="4 4" texuniform="true" reflectance="0.15"/>
    <material name="cube_mat" rgba="0.95 0.35 0.15 1"/>
    <material name="bowl_mat" rgba="0.25 0.65 0.55 0.7"/>
  </asset>

  <worldbody>
    <light name="key" pos="0 -1.5 2.5" dir="0 0 -1" directional="true" diffuse="0.8 0.8 0.8" ambient="0.25 0.25 0.25"/>
    <camera name="overview" pos="0.8 -0.55 0.75" xyaxes="0.738766 0.673962 0 -0.434228 0.47598 0.76478" fovy="45"/>
    <geom name="floor" type="plane" size="1.0 1.0 0.05" material="floor_mat"/>
    <geom name="workspace" type="box" pos="0.28 0 0.005" size="0.36 0.32 0.005" rgba="0.82 0.82 0.78 1"/>

    <body name="bowl" pos="0.28 0.19 0.01">
      <geom name="bowl_bottom" type="cylinder" size="0.07 0.008" material="bowl_mat"/>
      <geom name="bowl_front" type="box" pos="0 -0.067 0.014" size="0.072 0.006 0.014" material="bowl_mat"/>
      <geom name="bowl_back" type="box" pos="0 0.067 0.035" size="0.072 0.006 0.035" material="bowl_mat"/>
      <geom name="bowl_left" type="box" pos="-0.067 0 0.035" size="0.006 0.072 0.035" material="bowl_mat"/>
      <geom name="bowl_right" type="box" pos="0.067 0 0.035" size="0.006 0.072 0.035" material="bowl_mat"/>
      <site name="bowl_target" pos="0 0 0.04" size="0.01" rgba="0.1 0.9 0.1 0.7"/>
    </body>

    <body name="ball" pos="0.34 -0.14 0.035">
      <freejoint name="ball_freejoint"/>
      <geom name="ball_geom" type="box" size="0.022 0.022 0.022" mass="0.02" friction="3 0.05 0.001" condim="4" solimp="0.95 0.99 0.001" solref="0.004 1" material="cube_mat"/>
    </body>

    <body name="robot/base" pos="0 0 0.02">
      <geom name="base_geom" type="cylinder" size="0.055 0.025" rgba="0.18 0.18 0.18 1"/>
      <body name="robot/shoulder" pos="0 0 0.09">
        <joint name="robot/shoulder_pan_joint" type="hinge" axis="0 0 1" range="-3.14159 3.14159"/>
        <geom name="shoulder_geom" type="cylinder" size="0.04 0.04" class="arm_visual"/>
        <body name="robot/upper_arm" pos="0 0 0.04">
          <joint name="robot/shoulder_lift_joint" type="hinge" axis="0 1 0" range="-2.6 2.6"/>
          <geom name="upper_arm_geom" type="capsule" fromto="0 0 0 0.18 0 0" size="0.025" class="arm_visual"/>
          <body name="robot/forearm" pos="0.18 0 0">
            <joint name="robot/elbow_joint" type="hinge" axis="0 1 0" range="-2.6 2.6"/>
            <geom name="forearm_geom" type="capsule" fromto="0 0 0 0.16 0 0" size="0.022" class="arm_visual"/>
            <body name="robot/wrist_1" pos="0.16 0 0">
              <joint name="robot/wrist_1_joint" type="hinge" axis="0 1 0" range="-3.14159 3.14159"/>
              <geom name="wrist1_geom" type="capsule" fromto="0 0 0 0.055 0 0" size="0.018" class="arm_visual"/>
              <body name="robot/wrist_2" pos="0.055 0 0">
                <joint name="robot/wrist_2_joint" type="hinge" axis="1 0 0" range="-3.14159 3.14159"/>
                <geom name="wrist2_geom" type="sphere" size="0.023" class="arm_visual"/>
                <body name="robot/tool0" pos="0.055 0 0">
                  <joint name="robot/wrist_3_joint" type="hinge" axis="0 0 1" range="-3.14159 3.14159"/>
                  <geom name="palm" type="box" pos="0 0 -0.015" size="0.028 0.052 0.012" class="gripper"/>
                  <site name="pinch" pos="0 0 -0.085" size="0.006" rgba="0.9 0.9 0.9 0.8"/>
                  <body name="gripper/left_finger" pos="0 -0.046 -0.035">
                    <joint name="gripper/left_finger_joint" type="slide" axis="0 1 0" range="0 0.038" damping="2.0"/>
                    <geom name="left_pad" type="box" pos="0 0 -0.035" size="0.013 0.006 0.04" class="gripper"/>
                  </body>
                  <body name="gripper/right_finger" pos="0 0.046 -0.035">
                    <joint name="gripper/right_finger_joint" type="slide" axis="0 -1 0" range="0 0.038" damping="2.0"/>
                    <geom name="right_pad" type="box" pos="0 0 -0.035" size="0.013 0.006 0.04" class="gripper"/>
                  </body>
                </body>
              </body>
            </body>
          </body>
        </body>
      </body>
    </body>
  </worldbody>

  <equality>
    <joint name="finger_mimic" joint1="gripper/left_finger_joint" joint2="gripper/right_finger_joint" polycoef="0 1 0 0 0" solref="0.004 1" solimp="0.95 0.99 0.001"/>
  </equality>

  <actuator>
    <position name="robot/shoulder_pan" joint="robot/shoulder_pan_joint" kp="90" forcerange="-70 70" ctrlrange="-3.14159 3.14159"/>
    <position name="robot/shoulder_lift" joint="robot/shoulder_lift_joint" kp="90" forcerange="-70 70" ctrlrange="-2.6 2.6"/>
    <position name="robot/elbow" joint="robot/elbow_joint" kp="80" forcerange="-60 60" ctrlrange="-2.6 2.6"/>
    <position name="robot/wrist_1" joint="robot/wrist_1_joint" kp="45" forcerange="-25 25" ctrlrange="-3.14159 3.14159"/>
    <position name="robot/wrist_2" joint="robot/wrist_2_joint" kp="45" forcerange="-25 25" ctrlrange="-3.14159 3.14159"/>
    <position name="robot/wrist_3" joint="robot/wrist_3_joint" kp="35" forcerange="-20 20" ctrlrange="-3.14159 3.14159"/>
    <position name="gripper" joint="gripper/left_finger_joint" kp="350" forcerange="-35 35" ctrlrange="0 0.038"/>
  </actuator>
</mujoco>
